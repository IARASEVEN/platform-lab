# {{ ansible_managed }}
# Matches the Rocky 9 default config minus the DHCP sourcedir (the lab
# uses static addressing; there are no DHCP-provided NTP servers).
{% for pool in common_ntp_pools %}
pool {{ pool }} iburst
{% endfor %}

driftfile /var/lib/chrony/drift
makestep 1.0 3
rtcsync
keyfile /etc/chrony.keys
leapsectz right/UTC
logdir /var/log/chrony
